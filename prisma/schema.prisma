// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider        = "prisma-client"
  output          = "../generated/prisma"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [postgis]
}
enum UserRole {
  citizen
  authority
  admin
  org
}

enum ReportStatus {
  pending
  assigned
  resolved
  escalated
}

model User {
  id           Int            @id @default(autoincrement())
  name         String
  email        String         @unique
  passwordHash String         @map("password_hash")
  role         UserRole
  city         String
  impactScore  Float          @default(0) @map("impact_score")
  createdAt    DateTime       @default(now()) @map("created_at")
  reports      Report[]
  assignments  Assignment[]   @relation("AuthorityAssignments")
  campaigns    Campaign[]
  campaignJoins CampaignJoin[]

  @@map("users")
}

model Report {
  id                Int           @id @default(autoincrement())
  userId            Int           @map("user_id")
  imageUrl          String        @map("image_url")
  location          Unsupported("geography(Point, 4326)")
  addressText       String        @map("address_text")
  description       String
  category          String
  severity          String
  status            ReportStatus  @default(pending)
  aiConfidenceScore Float         @map("ai_confidence_score")
  createdAt         DateTime      @default(now()) @map("created_at")
  resolvedAt        DateTime?     @map("resolved_at")
  user              User          @relation(fields: [userId], references: [id])
  assignments       Assignment[]

  @@map("reports")
}

model Assignment {
  id             Int       @id @default(autoincrement())
  reportId       Int       @map("report_id")
  authorityId    Int       @map("authority_id")
  assignedAt     DateTime  @default(now()) @map("assigned_at")
  resolvedAt     DateTime? @map("resolved_at")
  beforeImageUrl String?   @map("before_image_url")
  afterImageUrl  String?   @map("after_image_url")
  report         Report    @relation(fields: [reportId], references: [id])
  authority      User      @relation("AuthorityAssignments", fields: [authorityId], references: [id])

  @@map("assignments")
}

model Campaign {
  id               Int            @id @default(autoincrement())
  createdBy        Int            @map("created_by")
  title            String
  description      String
  city             String
  date             DateTime
  participantCount Int            @default(0) @map("participant_count")
  createdAt        DateTime       @default(now()) @map("created_at")
  creator          User           @relation(fields: [createdBy], references: [id])
  joins            CampaignJoin[]

  @@map("campaigns")
}

model CampaignJoin {
  id         Int      @id @default(autoincrement())
  campaignId Int      @map("campaign_id")
  userId     Int      @map("user_id")
  joinedAt   DateTime @default(now()) @map("joined_at")
  campaign   Campaign @relation(fields: [campaignId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@unique([campaignId, userId])
  @@map("campaign_joins")
}
